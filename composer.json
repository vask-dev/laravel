{
    "name": "vask/laravel",
    "description": "Pusher-compatible websockets powered by vask.dev",
    "keywords": [
        "vask",
        "laravel",
        "websockets"
    ],
    "homepage": "https://github.com/vask-dev/laravel",
    "license": "MIT",
    "authors": [
        {
            "name": "Ashley Hindle",
            "email": "ashley@vask.dev",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0||^11.0||^12.0||^13.0",
        "pusher/pusher-php-server": "^7.2",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^7.10||^8.0",
        "larastan/larastan": "^2.9||^3.0",
        "orchestra/testbench": "^8.22||^9.0||^10.0||^11.0",
        "pestphp/pest": "^2.34||^3.0||^4.0",
        "pestphp/pest-plugin-arch": "^2.7||^3.0||^4.0",
        "pestphp/pest-plugin-laravel": "^2.4||^3.0||^4.0",
        "pestphp/pest-plugin-type-coverage": "^2.0||^3.0||^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^1.1||^2.0",
        "phpstan/phpstan-phpunit": "^1.3||^2.0",
        "rector/rector": "^1.0||^2.0",
        "driftingly/rector-laravel": "^1.0||^2.0",
        "roave/security-advisories": "dev-latest",
        "spatie/laravel-ray": "^1.35"
    },
    "autoload": {
        "psr-4": {
            "Vask\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vask\\Laravel\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "lint": [
            "vendor/bin/rector",
            "vendor/bin/pint --parallel"
        ],
        "test:lint": [
            "vendor/bin/rector --dry-run",
            "vendor/bin/pint --parallel --test"
        ],
        "test:types": "vendor/bin/phpstan analyse",
        "test:unit": "vendor/bin/pest --parallel",
        "test:coverage": "XDEBUG_MODE=coverage vendor/bin/pest --coverage --exactly=100.0",
        "test:type-coverage": "vendor/bin/pest --type-coverage --min=100",
        "test": [
            "@test:lint",
            "@test:types",
            "@test:type-coverage",
            "@test:unit"
        ],
        "format": "@lint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vask\\Laravel\\VaskServiceProvider"
            ],
            "aliases": {
                "Vask": "Vask\\Laravel\\Facades\\Vask"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
